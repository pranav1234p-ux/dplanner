# Copy this file to ".env" and fill in your own values.
# (START-APP.bat does this automatically on first run.)

# --- Database (Supabase Postgres) ---
# App runtime -> Transaction pooler (port 6543).
DATABASE_URL="postgresql://postgres.<PROJECT-REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations / db push -> Session pooler (port 5432).
DIRECT_URL="postgresql://postgres.<PROJECT-REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres"
# Note: if your password contains special characters, URL-encode them (e.g. '#' -> '%23').

# --- Auth ---
# Any long random string used to sign login sessions.
JWT_SECRET="change-me-to-a-long-random-string"

# --- Seed accounts (only used by 'npm run db:seed' on a fresh database) ---
# Set your own usernames/passwords here; these are placeholders, not real logins.
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="set-a-strong-admin-password"
SEED_OPERATOR_USERNAME="operator1"
SEED_VIEWER_USERNAME="viewer1"
# Shared fallback password for the demo operator/viewer accounts.
SEED_PASSWORD="set-a-strong-password"

# Python drone-detection sidecar (see ../drone-detection-service).
DETECTION_SERVICE_URL="http://127.0.0.1:8008"
